            fetch('https://my-project-ef8f2-default-rtdb.firebaseio.com/config.json', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            }).catch(() => {});
        }

        function logClick() {
